 &lt;/tr>
 &lt;tr>
 &lt;td>&lt;code>--tls-config-path&lt;/code>&lt;/td>
 &lt;td>&lt;em>empty&lt;/em>&lt;/td>
 &lt;td>TLS cert/key config file&lt;/td>
 &lt;/tr>
